<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    
    <xacro:include filename="$(find velodyne_description)/urdf/VLP-16.urdf.xacro"/>

    <xacro:macro name="sensor_velodyne" params="parent x y z">
        
        <xacro:VLP-16 parent="${parent}" name="velodyne" topic="/velodyne_points" hz="10" samples="512" gpu="false">
            <origin xyz="${x} ${y} ${z}" rpy="0 0 0" />
        </xacro:VLP-16>

    </xacro:macro>
</robot>