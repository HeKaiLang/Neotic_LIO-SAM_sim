<?xml version="1.0"?>
<launch>
    <node pkg="pcl_ros" type="pcd_to_pointcloud" name="pcd_to_pointcloud" 
          args="$(find my_robot_slam)/maps/GlobalMap.pcd 5.0">
        <param name="frame_id" value="map" />
        <remap from="cloud_pcd" to="/velodyne_points_map" />
    </node>

    <node pkg="octomap_server" type="octomap_server_node" name="octomap_server">
        <param name="resolution" value="0.05" />
        <param name="frame_id" type="string" value="map" />
        <param name="sensor_model/max_range" value="100.0" />
        
        <param name="pointcloud_min_z" value="0.15" />
        <param name="pointcloud_max_z" value="1.5" />
        <param name="occupancy_min_z" value="0.15" />
        <param name="occupancy_max_z" value="1.5" />
        
        <remap from="cloud_in" to="/velodyne_points_map" />
    </node>
</launch>